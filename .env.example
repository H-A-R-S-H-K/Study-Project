# Root env for docker-compose. Copy to .env and fill in before `docker compose up`.
# Per-service defaults live in the compose file; these are the secrets/overrides.

# ─── Secrets (REQUIRED in production) ─────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ─── CORS: comma-separated origins allowed to call the API ─
CORS_ORIGINS=http://localhost:8080

# ─── Cloudinary (image / document uploads) ────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── SMS gateway (OTP delivery). Empty → codes are logged. ─
SMS_PROVIDER_KEY=

# ─── Seeded admin (docker compose exec api npm run seed) ──
ADMIN_EMAIL=admin@vtc.local
ADMIN_PASSWORD=change_this_admin_password
