{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "jsx": "react-native",
    "allowJs": false,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "./src",
    "paths": {
      "@auth/*": ["auth/*"],
      "@customer/*": ["customer/*"],
      "@driver/*": ["driver/*"],
      "@vehicleOwner/*": ["vehicleOwner/*"],
      "@chat/*": ["chat/*"],
      "@notifications/*": ["notifications/*"],
      "@profile/*": ["profile/*"],
      "@maps/*": ["maps/*"],
      "@common/*": ["common/*"],
      "@redux/*": ["redux/*"],
      "@services/*": ["services/*"],
      "@navigation/*": ["navigation/*"],
      "@theme/*": ["theme/*"],
      "@types/*": ["types/*"],
      "@utils/*": ["utils/*"]
    }
  },
  "include": ["src", "App.tsx", "index.js"],
  "exclude": ["node_modules"]
}
